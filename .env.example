# PolarSeek environment template.
# Copy to `.env` (which is gitignored) and fill in. NEVER commit real secrets.
#
# PolarSeek's protocol CORE reads NO environment variables (keys are explicit or
# come from the keystore/ provider). These vars are only for OPS integrations you
# opt into — deployment, cloud KMS/HSM, TEE attestation, transparency-log hosting,
# and media generation. Anything blank is simply not wired.

# ── Deployment ────────────────────────────────────────────────────────────────
POLARSEEK_ENV=local                 # local | consortium | public
POLARSEEK_JURISDICTION=US

# ── GitHub (CI / signed releases / SLSA provenance) ─────────────────────────────
GITHUB_TOKEN=

# ── Key custody — Cloud KMS / HSM (keystore/ CloudKmsKeyProvider, Pkcs11KeyProvider)
# Azure Key Vault
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_KEY_VAULT_URL=
# AWS KMS (alternative)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_KMS_KEY_ID=
# PKCS#11 HSM (alternative)
PKCS11_MODULE_PATH=
PKCS11_PIN=

# ── TEE attestation (attest/ quote-verifier adapters) ───────────────────────────
TEE_PROVIDER=                       # tdx | sev-snp | cca   (when a verifier is wired)
AZURE_ATTESTATION_ENDPOINT=

# ── Transparency log operators (translog/ multi-operator gossip) ────────────────
POLARSEEK_LOG_OPERATORS=            # comma-separated operator endpoints

# ── Media generation — APPROVED allowlist only; raster only, NEVER SVG ──────────
ELEVENLABS_API_KEY=
KLING_API_KEY=
THENEWBLACK_API_KEY=
TOPAZ_API_KEY=
BFL_API_KEY=                        # Black Forest Labs (FLUX)
SHORTCUT_API_KEY=
CREATIFY_API_KEY=
ALPHAVANTAGE_API_KEY=
RUNWAY_API_KEY=
HEYGEN_API_KEY=
HEDRA_API_KEY=
