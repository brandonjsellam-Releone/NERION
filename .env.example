# PolarSeek environment template.
# Copy to `.env` (which is gitignored) and fill in. NEVER commit real secrets.
#
# PolarSeek's protocol CORE reads NO environment variables (keys are explicit or
# come from the keystore/ provider). These vars are only for OPS integrations you
# opt into — deployment, cloud KMS/HSM, TEE attestation, transparency-log hosting,
# and media generation. Anything blank is simply not wired.

# ── Deployment ────────────────────────────────────────────────────────────────
POLARSEEK_ENV=local                 # local | consortium | public
POLARSEEK_JURISDICTION=US

# ── GitHub (CI / signed releases / SLSA provenance) ─────────────────────────────
GITHUB_TOKEN=

# ── Key custody — Cloud KMS / HSM (keystore/ CloudKmsKeyProvider, Pkcs11KeyProvider)
# Azure Key Vault  (keystore/ AzureKeyVaultKeyProvider — KV seals the PQC seed at rest)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_KEY_VAULT_URL=
AZURE_KEY_VAULT_KEK_NAME=          # RSA wrapping key in the vault (default: polarseek-seal-kek)
# AWS KMS (alternative) — keystore/ AwsKmsKeyProvider seals the PQC seed with a
# symmetric KMS key (kms:Encrypt/Decrypt); SigV4-signed REST, no @aws-sdk.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_KMS_KEY_ID=
AWS_SESSION_TOKEN=                  # optional; only for temporary STS credentials
# PKCS#11 HSM (alternative) — keystore/ Pkcs11KeyProvider seals the PQC seed with
# a token-resident key. Supply a Pkcs11WrapEngine (wire pkcs11js to these).
PKCS11_MODULE_PATH=                  # path to the vendor module, e.g. .../libsofthsm2.so
PKCS11_PIN=
PKCS11_WRAP_KEY_LABEL=               # label of the RSA/AES wrapping key in the token

# ── TEE attestation (attest/ quote-verifier adapters) ───────────────────────────
TEE_PROVIDER=                       # tdx | sev-snp | cca   (when a verifier is wired)
AZURE_ATTESTATION_ENDPOINT=

# ── Transparency log operators (translog/ multi-operator gossip) ────────────────
POLARSEEK_LOG_OPERATORS=            # comma-separated operator endpoints

# ── Media generation — APPROVED allowlist only; raster only, NEVER SVG ──────────
ELEVENLABS_API_KEY=
KLING_API_KEY=
THENEWBLACK_API_KEY=
TOPAZ_API_KEY=
BFL_API_KEY=                        # Black Forest Labs (FLUX)
SHORTCUT_API_KEY=
CREATIFY_API_KEY=
ALPHAVANTAGE_API_KEY=
RUNWAY_API_KEY=
HEYGEN_API_KEY=
HEDRA_API_KEY=

# ── Council AI seats — new elite members (2026-06-24) ────────────────────────
# Nemotron 3 Ultra (NVIDIA NIM — OpenAI-compatible)
# Get key: https://build.nvidia.com → sign in → "Get API Key" on the Nemotron-3-Ultra page
# Model ID: nvidia/nemotron-3-ultra-550b-a55b
# Base URL: https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=

# Kimi K2 (Moonshot AI — OpenAI-compatible)
# Get key: https://platform.kimi.ai → sign in → API Keys
# Model ID (code+reasoning): kimi-k2.7-code-highspeed   |   general: kimi-k2.5
# Base URL: https://api.moonshot.ai/v1  (or https://api.moonshot.cn/v1 for CN)
MOONSHOT_API_KEY=
