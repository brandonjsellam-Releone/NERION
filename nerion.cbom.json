        "name": "nerion:cnsa-2.0",
        "value": "PS-5 uses the CNSA 2.0 algorithm set (ML-KEM-1024, ML-DSA-87, AES-256) at NIST Level 5; primary hash SHA-3/SHAKE256 (SHA-384 inside HMAC/HKDF) \u2014 aligned with CNSA 2.0 direction, not certified."
      },
      {
        "name": "nerion:agility",
        "value": "SuiteID registry: migration + compliance agility; hybrid-KEM composability; SuiteID bound into every signed message (signed-object suite-substitution rejected)."
      },
      {
        "name": "nerion:assurance",
        "value": "reference implementation; primitives via audited @noble libraries; protocol composition pending external audit (no FIPS/audit/non-infringement claim)"
      }
